    <selectionEntry id="6491-5e10-ba7e-e0d3" name="激光燧发枪" publicationId="bde1-6db1-163b-3b76" page="117" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="3284-5778-fb70-5f43" name="激光燧发枪" publicationId="bde1-6db1-163b-3b76" page="117" hidden="false" typeId="1a1a-e592-2849-a5c0" typeName="武器">
          <characteristics>
