    <selectionEntry id="51ed-f978-9a5e-1e04" name="机械法门" publicationId="bde1-6db1-163b-3b76" page="94" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e022-4319-4ae5-adf1" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5e23-856f-186d-618c" name="灵电刷新 (电灵仪式)" publicationId="bde1-6db1-163b-3b76" page="94" hidden="false" collective="true" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5944-ea7e-411e-f651" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="475b-312f-188b-e845" type="min"/>
          </constraints>
          <profiles>
            <profile id="ccb9-cbbc-d6b4-ff6b" name="灵电刷新 (电灵仪式)" publicationId="bde1-6db1-163b-3b76" page="94" hidden="false" typeId="5405-b3c6-e8d0-4e77" typeName="灵能">
              <characteristics>
                <characteristic name="描述" typeId="4c0f-7e2f-586c-9305">
                                    不进行射击攻击，电灵术士可以使用该秘仪以将其”战争铁匠（X）“特规作用效果增大，使其可以作用于电灵术士12
                                    寸内的一个有着”载具“，”无畏“或者”智械“单位词条的单独模型。该效果正常按照其原有的”战争铁匠（X）“特规生效，但是不需要电灵术士与模型底盘接触或者运载于模型之上。
                                    如果”战争铁匠（X）“的测试通过，那么玩家可以选择让该电灵术士进行一次”电灵术自检“。如果电灵术自检通过，那么”战争铁匠“特规额外生效多一次，不用投掷骰子（修复多一点W
                                    值，或者修复多一把已被摧毁的武器等。）如果电灵术自检失败，那么该电灵术士受到”电灵反噬“
                                </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="caa2-99d2-b7a0-21b7" name="灵电毁灭 (电灵秘器)" publicationId="bde1-6db1-163b-3b76" page="94" hidden="false" collective="true" import="true" type="upgrade">
