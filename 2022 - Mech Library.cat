    <selectionEntry id="9ccc-276b-eb67-9a0f" name="离子拳套盾" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="c622-aa22-5d98-69d2" name="离子拳套盾" hidden="false" typeId="2a1f-7837-f0ef-be44" typeName="装备">
          <characteristics>
            <characteristic name="描述" typeId="347e-ee4a-764f-6be3">装备有离子拳套盾的模型，对其前甲和侧甲的射击攻击拥有5+特保，对所有近战攻击5+特保。</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
      </costs>
    </selectionEntry>
    <selectionEntry id="dde9-961b-5765-21a2" name="离子护盾" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="dcde-df05-1912-9a61" name="离子护盾" hidden="false" typeId="2a1f-7837-f0ef-be44" typeName="装备">
          <characteristics>
            <characteristic name="描述" typeId="347e-ee4a-764f-6be3">装备有离子护盾的模型，面对射击其前甲的攻击获得4+ 特保，面对射击其侧甲的攻击获得5+特保。</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
      </costs>
    </selectionEntry>
    <selectionEntry id="c587-8d02-aaba-ce19" name="Ionic Deflector" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="d6e7-9365-6336-6a51" name="Ionic Deflector" hidden="false" typeId="2a1f-7837-f0ef-be44" typeName="装备">
          <characteristics>
            <characteristic name="描述" typeId="347e-ee4a-764f-6be3">A model with an ionic deflector gains a 5+ Invulnerable Save, and any model with an ionic deflector and a Wounds
                            Characteristic gains the Eternal Warrior special rule. In addition, when a model with an ionic deflector loses its last Wound or Hull Point, but before it is removed as a
                            casualty or replaced with a Wreck, all models both friendly and enemy within D6+3&quot; suffer an automatic Hit atStr 8, AP -.
                        </characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
      </costs>
    </selectionEntry>
