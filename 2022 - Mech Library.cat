                  <rules>
                    <rule id="48be-ab7a-6431-5d25" name="Avatar of Destruction" publicationId="bde1-6db1-163b-3b76" page="101" hidden="true">
                      <modifiers>
                        <modifier type="set" field="hidden" value="false">
                          <conditions>
                            <condition field="selections" scope="primary-category" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="4f85-eb33-30c9-8f51" type="instanceOf"/>
                          </conditions>
                        </modifier>
                      </modifiers>
                      <description>A single Thanatar Siege-automata Maniple unit consisting of a single model may be taken as a non-Compulsory HQ choice in a Detachment that
                                                includes a model with this special rule. This model must be replaced with a Thanatar-Calix and may not take the Paragon of Metal upgrade. While wholly
                                                within 6&quot; of a Thanatar-Calix taken as an HQ choice in this way, friendly Myrmidon Secutor Hosts and Myrmidon Destructor Hosts gain the Line Unit
                                                Sub-type and add +1 to the Wounds score used to determine if they win a combat in the Assault phase.
                                            </description>
                    </rule>
                  </rules>
