            <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e208-5a47-5937-4f5c" name="Encroaching Ruin" publicationId="44e-19f2-a369-b04e" page="8" hidden="false" collective="false" import="true" type="upgrade">
          <infoLinks>
            <infoLink id="3543-23e4-4cbe-a169" name="Encroaching Ruin" hidden="false" targetId="4438-874e-901d-f86" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6a9-eb18-8dc5-ef1c" name="Putrid Corruption" publicationId="44e-19f2-a369-b04e" page="8" hidden="false" collective="false" import="true" type="upgrade">
          <infoLinks>
            <infoLink id="ba33-7b89-512c-7bbf" name="Putrid Corruption" hidden="false" targetId="94eb-7da4-953-529f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7ad-bd12-1203-4018" name="Infernal Tempest" publicationId="44e-19f2-a369-b04e" page="8" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="d825-9702-7cd0-1fe" name="Empyreal Tempest (Psychic Weapon)" publicationId="44e-19f2-a369-b04e" page="8" hidden="false" typeId="cede-0217-1b10-2a34" typeName="灵能武器">
              <characteristics>
                <characteristic name="距离" typeId="62ec-fbf5-5252-0d17">12&quot;</characteristic>
                <characteristic name="S" typeId="17ff-12e7-77d3-2fbe">5</characteristic>
                <characteristic name="AP" typeId="f431-a7b9-d9d0-36c9">2</characteristic>
                <characteristic name="类型" typeId="2159-62b6-4337-d516">重型 1, 爆炸 (3&quot;), Guided Fire, Psychic Focus</characteristic>
              </characteristics>
            </profile>
            <profile id="29c3-99da-b4d8-2404" name="Infernal Warding (Psychic Power)" publicationId="44e-19f2-a369-b04e" page="8" hidden="false" typeId="5405-b3c6-e8d0-4e77" typeName="灵能">
              <characteristics>
                <characteristic name="描述" typeId="4c0f-7e2f-586c-9305">At the start of any of the controlling player’s turns, a model with this power may choose to make a Psychic
                                    check. If the Check is passed, the model with this power gains +1 to their Invulnerable Save, to a maximum of 3+, until the start of the controlling player’s next
                                    player turn. If the Check is failed, the model suffers Perils of the Warp and gains no benefit.
                                </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="acc2-537b-ff29-991e" name="Psychic Focus" hidden="false" targetId="bff3-3548-b2b8-72f1" type="rule"/>
            <infoLink id="2b0e-5f20-f672-ea98" name="Infernal Tempest" hidden="false" targetId="457b-86dd-cedd-ce60" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="25.0"/>
          </costs>
        </selectionEntry>
