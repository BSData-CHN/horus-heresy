      </constraints>
      <selectionEntries>
        <selectionEntry id="8bc8-6c30-409f-8f27" name="Conqueror of Worlds (0-1)" publicationId="44e-19f2-a369-b04e" page="7" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditionGroups>
                <conditionGroup type="or">
                  <conditions>
                    <condition field="selections" scope="ancestor" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="8cb2-7235-fc34-9983" type="instanceOf"/>
                    <condition field="selections" scope="ancestor" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="7b6b-49ab-d71d-e359" type="instanceOf"/>
                  </conditions>
                </conditionGroup>
              </conditionGroups>
            </modifier>
          </modifiers>
          <constraints>
            <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d855-dfe1-4f37-d3c0" type="max"/>
          </constraints>
          <rules>
            <rule id="7b98-d37b-e98b-1d60" name="Conqueror of Worlds (0-1)" publicationId="44e-19f2-a369-b04e" page="7" hidden="false">
              <description>A model with this upgrade gains the Character Unit Sub-type and increases its Weapon Skill and Ballistic Skill Characteristics by +1. In addition, if the
                                Questoris Household Detachment is the Primary Detachment of the army, then a model with this upgrade must be chosen is the army’s Warlord. If selected as the army’s
                                Warlord, a model with this upgrade automatically gains the following Warlord Trait:
                            </description>
            </rule>
          </rules>
          <costs>
            <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="80.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4d39-37c3-366-9cbd" name="Heedless Slaughter" publicationId="44e-19f2-a369-b04e" page="7" hidden="false" collective="false" import="true" type="upgrade">
          <infoLinks>
            <infoLink id="a04f-92eb-66e1-dc45" name="Heedless Slaughter" hidden="false" targetId="a57e-1003-3f17-d12e" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d6ff-d1db-10d2-9280" name="Malevolent Artifice" publicationId="44e-19f2-a369-b04e" page="8" hidden="false" collective="false" import="true" type="upgrade">
          <infoLinks>
            <infoLink id="7335-9c66-777a-d5cc" name="It Will Not Die (X)" hidden="false" targetId="2784-d0be-a4e2-890f" type="rule"/>
            <infoLink id="de1e-6bee-f53f-de9c" name="Malevolent Artifice" hidden="false" targetId="c488-ac28-c303-57b" type="rule"/>
          </infoLinks>
