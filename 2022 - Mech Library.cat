    <selectionEntry id="7908-9b34-c5bb-21c2" name="Mechanicum Protectiva" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4f0e-2878-6e2c-eaeb" type="max"/>
      </constraints>
      <profiles>
        <profile id="69de-85b2-7a04-eaf2" name="Mechanicum Protectiva" hidden="false" typeId="2a1f-7837-f0ef-be44" typeName="装备">
          <characteristics>
            <characteristic name="描述" typeId="347e-ee4a-764f-6be3">A model with a Mechanicum Protectiva gains a 4+ Invulnerable Save.
                            Invulnerable Saves granted by a Mechanicum Protectiva do not stack with other Invulnerable Saves, but can benefit from rules (like cyber-familiar) that specifically
                            increase existing Saves. If a model has another Invulnerable Save then the controlling player must choose which one to use.
                        </characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
      </costs>
    </selectionEntry>
    <selectionEntry id="d342-dbdb-33ec-5191" name="智控法门" publicationId="bde1-6db1-163b-3b76" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c2ef-891c-51e8-5728" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="dead-87ed-fb0d-0628" name="智控电激 (电灵仪式)" publicationId="bde1-6db1-163b-3b76" page="94" hidden="false" collective="true" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="255b-8955-ef87-9ea2" type="min"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d9e4-d354-e70d-8649" type="max"/>
          </constraints>
          <profiles>
            <profile id="11fa-16c9-2547-4274" name="智控电激 (电灵仪式)" publicationId="bde1-6db1-163b-3b76" page="94" hidden="false" typeId="5405-b3c6-e8d0-4e77" typeName="灵能">
              <characteristics>
                <characteristic name="描述" typeId="4c0f-7e2f-586c-9305">
                                    不进行射击攻击，电灵术士可以使用该秘仪选择12寸内的一个友方单位，且该单位内至少有一个模型有着”智控“单位词条。将下述效果之一运用该单位内所有有着“智控”单位词条的模型：
                                    仪式作用后，进行冲锋骰投掷时，投2D6时额外投掷一颗骰子，并弃掉3 颗骰子中结果最小的那一颗。
                                    在下一个己方玩家回合开始前，整个单位（并非每个模型）忽视每一轮对其的射击攻
                                    击所产生的第一个伤。这是直接抛弃这个伤而非将其分配到某个模型伤。
                                    ⚫ 该仪式作用后，此单位在该射击阶段获得BS+1。
                                    ⚫ 在下一个己方玩家回合开始前，作为反应玩家时，该单位忽视“智控”单位词条所带来的不能做反应动作的限制。
                                    电灵术士可以在使用能力前进行一个“电灵术自检”，如果测试通过，那么可以选择两个不同的效果进行生效，而不是一个。如果测试失败，那么不能选择任何的效果，且电灵术士受到“电灵反噬”。
                                </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d3cc-0712-8f4a-7f56" name="穿刺筹算 (电灵秘器)" publicationId="bde1-6db1-163b-3b76" hidden="false" collective="true" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="875e-e2b2-4fb0-788e" type="min"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5892-ea07-8441-baca" type="max"/>
