    <selectionEntry id="12fc-d4d8-d36c-6f14" name="微灵攻讦" publicationId="bde1-6db1-163b-3b76" page="95" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e7fd-f043-090d-e79c" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="0c41-188d-3206-fb63" name="微灵策反 (电灵仪式)" publicationId="bde1-6db1-163b-3b76" page="95" hidden="false" collective="true" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7945-2055-8c27-fda5" type="min"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ff24-d09e-b3dc-19dc" type="max"/>
          </constraints>
          <profiles>
            <profile id="90d2-faf0-e267-7e00" name="微灵策反 (电灵仪式)" publicationId="bde1-6db1-163b-3b76" page="95" hidden="false" typeId="5405-b3c6-e8d0-4e77" typeName="灵能">
              <characteristics>
                <characteristic name="描述" typeId="4c0f-7e2f-586c-9305">
                                    不进行射击攻击，电灵术士可以使用该秘仪，选择至少有一个模型在其12 寸内的 “载具”或者“智械”单位词条的敌方单位。
                                    电灵秘术方玩家可以立即让其进行一轮射击攻击，就好像是他控制着这个被选定的单位。这轮射击可以攻击任意被电灵术士方玩家视作敌方单位的单位，但该次攻击是仓促攻击。
                                    电灵术士可以选择进行一次“电灵术自检”在进行这轮射击攻击前，如果成功，这次攻击将会使用电灵术士的BS值而非仓促射击。如果失败，电灵术士受到“电灵反噬”，并且不能进行概论设计。
                                    一个进行该轮射击攻击的敌方单位在其玩家回合照常攻击，并且在接下来的游戏里获得“仇恨（电灵术士）” 特规。
                                </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="17f3-49ff-d6da-c8d1" name="微灵闪清 (电灵秘器)" publicationId="bde1-6db1-163b-3b76" page="95" hidden="false" collective="true" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2e72-fb09-75b2-d7f1" type="min"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3a7f-7acc-120b-735a" type="max"/>
          </constraints>
          <profiles>
