    <selectionEntry id="b627-88f0-ee8c-c43c" name="还原法门" publicationId="bde1-6db1-163b-3b76" page="96" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1c8e-aaf1-7efa-f4c6" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d46c-b64d-855c-37f5" name="门破灵碎 (电灵仪式)" publicationId="bde1-6db1-163b-3b76" page="96" hidden="false" collective="true" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5748-7f1e-fae0-ed19" type="min"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ae65-37c3-e8e6-dc1e" type="max"/>
          </constraints>
          <profiles>
            <profile id="90f2-78f1-92ea-3c5a" name="门破灵碎 (电灵仪式)" publicationId="bde1-6db1-163b-3b76" page="96" hidden="false" typeId="5405-b3c6-e8d0-4e77" typeName="灵能">
              <characteristics>
                <characteristic name="描述" typeId="4c0f-7e2f-586c-9305">
                                    不进行射击攻击，电灵术士可以使用该秘仪，选择12 寸内一个单独的有一个敌方单位运载于其上的建筑，工事或者有着“运输载具”单位子词条的敌方单位，然后必须进行一次“电灵术自检”。
                                    如果测试成功，运载于其上的敌方单位必须立即进行紧急下车并且下车时必须进行压制测试。如果测试失败，电灵术士收到 电灵反噬 。
                                    这个仪式不能作用于有着“飞行器”，“超重型”，“骑士”或者“泰坦”单位子词条的敌方模型。
                                </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f8bb-912d-7f54-eb0e" name="应流毁灭 (电灵秘器)" publicationId="bde1-6db1-163b-3b76" page="96" hidden="false" collective="true" import="true" type="upgrade">
