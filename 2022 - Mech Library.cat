          <selectionEntries>
            <selectionEntry id="6a5b-c782-05b5-df3d" name="冷铁铸魂" publicationId="bde1-6db1-163b-3b76" page="16" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="set" field="hidden" value="true">
                  <conditionGroups>
                    <conditionGroup type="or">
                      <conditions>
                        <condition field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="63ce-0429-b209-c3e9" type="equalTo"/>
                        <condition field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="8bc8-6c30-409f-8f27" type="equalTo"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </modifier>
              </modifiers>
              <constraints>
                <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="996a-f8ad-623a-d3a1" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2fb2-8c4a-f16c-68bf" type="max"/>
              </constraints>
              <profiles>
                <profile id="cbea-05d8-aa54-76be" name="冷铁铸魂" publicationId="bde1-6db1-163b-3b76" page="16" hidden="false" typeId="a0e6-a7b4-d55d-85b8" typeName="主将特性">
                  <characteristics>
                    <characteristic name="描述" typeId="c68e-2cda-b67b-baca">拥有该主将特性的主将及其6 寸内的被压制的友方单位（有一个模型在主将6
                                            寸内即可），可以正常移动和宣布冲锋，但在压制状态解除之前，他都只能仓促射击。除此之外，当该选择该主将特性的主将仍存活在桌面上，并未因伤亡而移除时，其军队能在敌方的移动阶段做额外的一个反应。
                                        </characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="72e5-d0a2-9e1d-5ea8" name="致胜逻辑" publicationId="bde1-6db1-163b-3b76" page="16" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="set" field="hidden" value="true">
                  <conditionGroups>
                    <conditionGroup type="or">
                      <conditions>
                        <condition field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="63ce-0429-b209-c3e9" type="equalTo"/>
                        <condition field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="8bc8-6c30-409f-8f27" type="equalTo"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </modifier>
              </modifiers>
              <constraints>
                <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f54b-d090-15b4-2c42" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="134f-b4d5-8456-805a" type="max"/>
              </constraints>
              <profiles>
                <profile id="a8e3-4bf0-89e7-df2c" name="致胜逻辑" publicationId="bde1-6db1-163b-3b76" page="16" hidden="false" typeId="a0e6-a7b4-d55d-85b8" typeName="主将特性">
                  <characteristics>
                    <characteristic name="描述" typeId="c68e-2cda-b67b-baca">
                                            拥有该主将特性的主将，只要在作为激活玩家时的一整个小回合没有锁入近战或者进行射击攻击，那么军队就可以在接下来的敌方回合每一个阶段都额外做一个反应动作。除此之外，拥有该主将特性的主将及其加入的单位，其在做反应动作（攻击类）时获得B
                                            S+1 和W S+1 1；在做反应动作（移动类）获得I +3 或者M +3 。
                                        </characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="9a75-f183-2c0f-1b16" name="屠戮学识" publicationId="bde1-6db1-163b-3b76" page="16" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="set" field="hidden" value="true">
                  <conditionGroups>
                    <conditionGroup type="or">
                      <conditions>
                        <condition field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="63ce-0429-b209-c3e9" type="equalTo"/>
                        <condition field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="8bc8-6c30-409f-8f27" type="equalTo"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </modifier>
              </modifiers>
              <constraints>
                <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="1771-b611-d8ac-c618" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cd28-09fa-c134-21c8" type="max"/>
              </constraints>
              <profiles>
                <profile id="ce31-6742-a3ac-466e" name="屠戮学识" publicationId="bde1-6db1-163b-3b76" page="16" hidden="false" typeId="a0e6-a7b4-d55d-85b8" typeName="主将特性">
                  <characteristics>
                    <characteristic name="描述" typeId="c68e-2cda-b67b-baca">当拥有该主将特性的主将在一场近战的第二轮（即第一轮打平后），会获得WS+1 和S
                                            +1，且自第二轮后每多进行一轮便会再获得一次此效果（最高为10）（即第二轮开始WS+1 ，第三轮开始时WS+2 ）。一旦给定的一场近战结束，而该主将也未被锁入近战，那么主将的WS
                                            值和S 值都会被重设至初始值。除此之外，当该选择该主将特性的主将仍存活在桌面上，并未因伤亡而移除时，其军队能在敌方的突击阶段做额外的一个反应。
                                        </characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="be13-4974-e7da-06be" name="家族之主" hidden="true" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="set" field="66e8-a9d4-27fa-a9dc" value="1">
                  <conditionGroups>
                    <conditionGroup type="or">
                      <conditions>
                        <condition field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="63ce-0429-b209-c3e9" type="equalTo"/>
                        <condition field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="8bc8-6c30-409f-8f27" type="equalTo"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </modifier>
                <modifier type="set" field="hidden" value="false">
                  <conditionGroups>
                    <conditionGroup type="or">
                      <conditions>
                        <condition field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="63ce-0429-b209-c3e9" type="equalTo"/>
                        <condition field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="8bc8-6c30-409f-8f27" type="equalTo"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </modifier>
              </modifiers>
              <constraints>
                <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4329-f6f0-2b2d-3fa4" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cafb-c4ca-77a4-2107" type="max"/>
                <constraint field="selections" scope="parent" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="66e8-a9d4-27fa-a9dc" type="min"/>
              </constraints>
              <profiles>
                <profile id="db47-e617-14ca-4bdb" name="家族之主" publicationId="bde1-6db1-163b-3b76" page="88" hidden="false" typeId="a0e6-a7b4-d55d-85b8" typeName="主将特性">
                  <characteristics>
                    <characteristic name="描述" typeId="c68e-2cda-b67b-baca">任意在该主将8
                                            寸内的有着“载具”单位词条和“骑士”单位子词条的友方模型，可以照常进行反应动作，忽视骑士与泰坦对于反应动作的限制。除此之外，当该选择该主将特性的主将仍存活在桌面上，并未因伤亡而移除时，其军队能在敌方的射击阶段做额外的一个反应。
                                        </characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="分" typeId="d2ee-04cb-5f8a-2642" value="0.0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
        </selectionEntryGroup>
      </selectionEntryGroups>
